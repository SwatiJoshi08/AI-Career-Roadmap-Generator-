    "import-onet": "ts-node src/scripts/runOnetImport.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.32.0",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.2",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.76.0",
    "p-limit": "^3.1.0",
    "uuid": "^11.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.3",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nock": "^14.0.15",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }

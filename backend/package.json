{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for AI Career Roadmap Generator",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "audit-urls": "ts-node src/scripts/auditUrls.ts",
    "test:coverage": "jest --runInBand --coverage",

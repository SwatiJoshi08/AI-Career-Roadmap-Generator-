# The environment type (development, production, test)
NODE_ENV=
# The port number the Express server will listen on
PORT=
# The MongoDB connection URI (including credentials and database name)
MONGODB_URI=
# The Redis URL for ioredis and BullMQ queues
REDIS_URL=
# Secret key used for signing JWT access tokens
JWT_SECRET=
# Expiration time for JWT access tokens (e.g., 1d, 1h, 15m)
JWT_EXPIRES_IN=
# Secret key used for session cookies/tokens validation
SESSION_SECRET=
# Cloudinary account cloud name for image/document uploads
CLOUDINARY_CLOUD_NAME=
# Cloudinary API key for authentication
CLOUDINARY_API_KEY=
# Cloudinary API secret for authentication (never share this!)
CLOUDINARY_API_SECRET=
# Groq API key for accessing Groq models
GROQ_API_KEY=
# The AI model identifier to use
AI_MODEL=
# The URL of the frontend client application (CORS allowed origin)
APP_ORIGIN=
# Minimum logging level threshold (e.g., debug, info, warn, error)
LOG_LEVEL=
